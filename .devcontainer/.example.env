# ─── Open Harness — Local Configuration ─────────────────────────────
# This gitignored file is the surface for host-local defaults and secrets.
# The installer writes sandbox name / timezone / git identity here so the
# tracked checkout stays clean and updateable. Broader non-secret defaults
# can live in tracked `harness.yaml`; keys set in harness.yaml WIN over
# this file.
#
# To apply changes:
#
#     make destroy && make sandbox
#
# install.sh generates `.devcontainer/.env` with host defaults
# (sandbox name, timezone, git identity, gh token if opted in).
# Manual setup (no installer): cp .devcontainer/.example.env .devcontainer/.env
#
# Back-compat note: values still set in an existing .devcontainer/.env
# continue to work unless overridden by harness.yaml.

# ─── Migrated to harness.yaml ────────────────────────────────────────
# The following vars were removed from this file. Set them in harness.yaml
# using the keys shown. Values in an existing .env still take effect unless
# overridden by harness.yaml.
#
#   SANDBOX_NAME          → name:
#   TZ                    → timezone:
#   CRONS_DIR             → crons.dir:
#   CRON_AGENT_BIN        → crons.agent_bin:
#   INSTALL_AGENT_BROWSER → install.agent_browser:
#   INSTALL_OPENCODE      → install.opencode:
#   INSTALL_GROK_BUILD    → install.grok_build:
#   INSTALL_DEEPAGENTS    → install.deepagents:
#   INSTALL_HERMES        → install.hermes:
#   HERMES_DASHBOARD      → hermes.dashboard:
#   HERMES_DASHBOARD_PORT → hermes.dashboard_port:
#   GIT_USER_NAME         → git.user_name:
#   GIT_USER_EMAIL        → git.user_email:
#   SLACK_ALLOW_USERS     → slack.allow_users:
#   SLACK_ALLOW_CHANNELS  → slack.allow_channels:

# ─── GitHub (primary git auth method) ────────────────────────────────
# Personal Access Token for GitHub CLI authentication inside the sandbox.
# On startup, entrypoint auto-runs `gh auth login`, `gh auth setup-git`,
# and (if `admin:public_key` scope is granted) generates an ed25519 SSH
# key and uploads the public key to GitHub — no interactive prompts.
# Recommended: Set this for frictionless git operations and gh CLI automation.
# Create one at: https://github.com/settings/tokens?type=beta
# Scopes needed: repo, read:org, admin:public_key (for SSH key upload)
GH_TOKEN=

# ─── xAI / Grok Build ───────────────────────────────────────────────
# Optional API key fallback for the Grok Build CLI. The preferred browser or
# device auth flow writes persistent state under ~/.grok (Docker volume), but
# this secret can be passed through for non-interactive use.
# XAI_API_KEY=

# ─── Slack bot (Pi extension) ────────────────────────────────────────
# The in-tree Pi extension at .pi/extensions/slack/ bridges Slack
# messages into a Pi agent over Socket Mode. Read from process.env at
# session_start; no compose overlay needed.
#
# Load into the shell that launches `pi` inside the sandbox:
#     set -a; source /home/sandbox/harness/.devcontainer/.env; set +a
# `set -a` is required because this file uses Compose's KEY=value
# format (no `export`); without it, sourced vars stay in the shell
# and aren't inherited by child processes like `pi`.
#
# Allowlist vars (SLACK_ALLOW_USERS / SLACK_ALLOW_CHANNELS) now live in
# harness.yaml under the `slack:` section.
# See docs/integrations/slack.md and .pi/extensions/slack/README.md.

# Slack app-level token for Socket Mode connection (starts with xapp-).
# SLACK_APP_TOKEN=xapp-...

# Slack bot OAuth token for posting messages (starts with xoxb-).
# SLACK_BOT_TOKEN=xoxb-...
