# ─── Open Harness — Environment Configuration ──────────────────────
# This is the single customization surface for the sandbox.
#
# install.sh writes a generated .devcontainer/.env that mirrors this
# template, populated with safe defaults (host gh token if you opted in,
# host timezone, host git identity). To re-apply changes:
#
#     edit .devcontainer/.env
#     make destroy && make sandbox
#
# Manual setup (no installer): cp .devcontainer/.example.env .devcontainer/.env

# ─── Sandbox ────────────────────────────────────────────────────────

# Name used for the Docker container, compose project, and CLI commands.
# Example: openharness shell $SANDBOX_NAME
SANDBOX_NAME=oh-local

# ─── Timezone ───────────────────────────────────────────────────────

# Sets the container's timezone. Affects cron schedules, log timestamps,
# and any time-aware tools inside the sandbox.
TZ=America/Denver

# ─── GitHub (primary git auth method) ────────────────────────────────
# Personal Access Token for GitHub CLI authentication inside the sandbox.
# On startup, entrypoint auto-runs `gh auth login`, `gh auth setup-git`,
# and (if `admin:public_key` scope is granted) generates an ed25519 SSH
# key and uploads the public key to GitHub — no interactive prompts.
# Recommended: Set this for frictionless git operations and gh CLI automation.
# Create one at: https://github.com/settings/tokens?type=beta
# Scopes needed: repo, read:org, admin:public_key (for SSH key upload)
GH_TOKEN=

# ─── Crons (autonomous agent scheduling) ─────────────────────────────
# Scheduled agent invocations live in crons/*.md — each file is a YAML
# frontmatter block (schedule, timezone, enabled, overlap) followed by
# a markdown body that becomes the agent prompt. The croner runtime at
# scripts/cron-runtime.ts loads them at boot inside the system-cron
# tmux session. See crons/README.md for the file shape and conventions.

# Override the directory the runtime scans (default: crons).
# CRONS_DIR=crons

# Override the agent binary used to fire scheduled tasks (default: claude).
# CRON_AGENT_BIN=claude

# ─── Agent Browser (optional) ───────────────────────────────────────
# Set to true to install agent-browser + Chromium on container startup
# (~1 GB, adds ~3 min to first build). Disabled by default — enable
# only when you need headless browser automation.
INSTALL_AGENT_BROWSER=false

# ─── Hermes Agent CLI (optional) ─────────────────────────────────────
# Set to true to install Nous Research's Hermes agent CLI on container
# startup via the official curl-piped installer (lands binary on PATH;
# config + credentials persist to ~/.hermes via the hermes-auth named
# volume). Disabled by default — enable only when you want `hermes`
# available alongside claude/codex/pi/opencode/deepagents.
INSTALL_HERMES=false

# ─── Slack bot (Pi extension) ────────────────────────────────────────
# The in-tree Pi extension at .pi/extensions/slack/ bridges Slack
# messages into a Pi agent over Socket Mode. Read from process.env at
# session_start; no compose overlay needed.
#
# Load into the shell that launches `pi` inside the sandbox:
#     set -a; source /home/sandbox/harness/.devcontainer/.env; set +a
# `set -a` is required because this file uses Compose's KEY=value
# format (no `export`); without it, sourced vars stay in the shell
# and aren't inherited by child processes like `pi`.
#
# At least one of SLACK_ALLOW_USERS / SLACK_ALLOW_CHANNELS must be set
# or the extension denies all events (fail-safe default).
# See docs/integrations/slack.md and .pi/extensions/slack/README.md.

# Slack app-level token for Socket Mode connection (starts with xapp-).
# SLACK_APP_TOKEN=xapp-...

# Slack bot OAuth token for posting messages (starts with xoxb-).
# SLACK_BOT_TOKEN=xoxb-...

# Comma-separated Slack user IDs allowed to talk to the bot (U…).
# SLACK_ALLOW_USERS=U01ABCD2345

# Comma-separated Slack channel IDs the bot will respond in (C…).
# SLACK_ALLOW_CHANNELS=C01ABCD2345

