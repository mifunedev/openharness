.mifune/skills.lock.lck
**/.env*
# Derived env artifact generated by Makefile from harness.yaml (not matched by **/.env*)
.devcontainer/.harness.yaml.env
/.oh/config.json
.worktrees/*
.claude/worktrees/
.oh/tasks/archive/
!.worktrees/README.md

# Build artifacts
**/.venv/
**/node_modules/
**/dist/
*.tsbuildinfo

# IDE
.vscode/
.idea/

# Screenshots (keep dir, ignore contents)
**/.claude/screenshots/*
!**/.claude/screenshots/.gitkeep

# Croner runtime artifacts (keep .oh/crons/*.md tracked)
.oh/crons/.pid
.oh/crons/*.log

# Ralph runtime files (keep prd.json + progress.txt tracked for recovery)
workspace/.ralph/.last-branch
workspace/.ralph/ralph-*.log
workspace/.ralph/.claude/

# pi-autoresearch runtime state (benchmarks, logs, session config)
**/.auto/

**/.next
**/.ralph/archives/
**/src/generated/

# Slack runtime data (channel logs, context, attachments — keep MEMORY.md tracked)
workspace/.slack/*/
workspace/.slack/events/
workspace/.slack/settings.json

# Daily session logs — .oh/memory/README.md, .oh/memory/MEMORY.md, and topic notes are tracked
.oh/memory/[0-9]*/

# Pi project config (generated symlinks)
workspace/.pi/

# Startup script (contains runtime config, tokens sourced from env)
workspace/startup.sh
**/.pnpm-store
**/.claude/plans
**/.claude/specs/*
**/auth.json
**/.credentials.json

# Hermes project-local runtime state (keep README tracked)
/.hermes/*
!/.hermes/README.md
!/.hermes/hooks/

**/scheduled_tasks.lock
# Legacy/future workspace package build artifacts
packages/*/build/
packages/*/node_modules/
# Wiki corpus owned by the /wiki skill — entries are local scratch by default;
# the operator whitelists curated entries into git with `git add -f`. Raw
# snapshots are immutable provenance, fully ignored except the directory anchor.
.mifune/skills/wiki/corpus/*
!.mifune/skills/wiki/corpus/README.md
!.mifune/skills/wiki/corpus/raw/
.mifune/skills/wiki/corpus/raw/*
!.mifune/skills/wiki/corpus/raw/README.md
