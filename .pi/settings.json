  "themes": ["./themes"],
  "enableSkillCommands": true,
  "packages": [
    "npm:@tintinweb/pi-subagents@0.7.1",
    "npm:@tintinweb/pi-tasks@0.7.0",
    "npm:@tintinweb/pi-goal"
  ]
}
