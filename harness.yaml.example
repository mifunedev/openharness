# harness.yaml.example — Open Harness master config template (tracked).
#
# Copy to local gitignored harness.yaml before building (`make harness-config`).
# Everything non-secret lives in harness.yaml. Secrets (GH_TOKEN,
# PI_SLACK_APP_TOKEN, PI_SLACK_BOT_TOKEN) live ONLY in gitignored
# .devcontainer/.env. Keys set in harness.yaml OVERRIDE .devcontainer/.env
# for the same setting.
#
# Format: flat two-level section/key only — parsed by
# scripts/harness-config.sh (plain awk; no yq). No anchors or nesting
# beyond the compose.overrides list. Commented keys are inactive
# (.env / compose defaults apply) — every key ships commented with its
# default shown, so a fresh clone changes nothing; uncomment to take over
# a setting from .env.
#
# Apply harness.yaml changes with: make destroy && make sandbox

sandbox:
  # name: openharness          # SANDBOX_NAME — container + compose project name
  # timezone: America/Los_Angeles   # TZ — cron schedules, log timestamps
  # docker_socket: false       # DOCKER_SOCKET — mount host /var/run/docker.sock (effectively host root; opt-in)
  # image: ghcr.io/mifunedev/openharness:latest   # OH_SANDBOX_IMAGE — run the prebuilt image instead of a local build (pair with `oh sandbox --image`)
  # pull_policy: missing        # OH_PULL_POLICY — compose pull policy for the image (missing|always|never); used by the VS Code "Reopen in Container" path

git:
  # user_name: Your Name           # GIT_USER_NAME (spaces OK)
  # user_email: you@example.com    # GIT_USER_EMAIL

install:
  # opencode: false            # INSTALL_OPENCODE — OpenCode CLI (build arg)
  # grok_build: false          # INSTALL_GROK_BUILD — Grok Build CLI (build arg)
  # deepagents: false          # INSTALL_DEEPAGENTS — DeepAgents CLI (build arg)
  # hermes: false              # INSTALL_HERMES — Hermes CLI (build arg + runtime)
  # agent_browser: false       # INSTALL_AGENT_BROWSER — agent-browser + Chromium (~1 GB)

hermes:
  # dashboard: false           # HERMES_DASHBOARD — auto-start web dashboard when Hermes is installed
  # dashboard_port: 9119       # HERMES_DASHBOARD_PORT — host loopback port for the dashboard

crons:
  # dir: .oh/crons             # CRONS_DIR — directory the cron runtime scans
  # agent_bin: claude          # CRON_AGENT_BIN — binary that fires scheduled tasks

paths:
  # memory: .oh/memory         # MEMORY_DIR — long-term memory + dated session logs
  # worktrees: .oh/worktrees   # WORKTREES_DIR — ignored git worktree and project-clone root

autopilot:
  # Configurable defaults for the deterministic caps gate
  # (.oh/skills/autopilot/autopilot-caps.sh, wired as the autopilot cron's `preflight:`).
  # Read live at each fire — uncomment to change without a rebuild. An
  # AUTOPILOT_TOTAL_CAP / AUTOPILOT_DAILY_CAP env var still overrides these.
  # total_cap: 10              # AUTOPILOT_TOTAL_CAP — max open autopilot PRs at any time
  # daily_cap: 6               # AUTOPILOT_DAILY_CAP — max open autopilot PRs created per UTC day

slack:
  # Slack is configured via the pi-messenger-bridge package, not here.
  # Tokens PI_SLACK_APP_TOKEN / PI_SLACK_BOT_TOKEN live in .devcontainer/.env;
  # runtime config (autoConnect, challenge-auth trustedUsers) lives in
  # ~/.pi/msg-bridge.json. There is no static allowlist — auth is runtime
  # challenge-based. See .oh/docs/integrations/slack.md.

compose:
  # Tracked overlay paths, applied before user-local config.json
  # composeOverrides[] (last -f wins → user-local beats tracked).
  # overrides:
  #   - .devcontainer/docker-compose.example.yml
