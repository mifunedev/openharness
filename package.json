{
  "name": "openharness",
  "version": "0.1.0",
  "private": true,
  "description": "Open Harness \u2014 AI Agent Sandbox Orchestrator",
  "type": "module",
  "packageManager": "pnpm@10.33.0",
  "scripts": {
    "setup": "pnpm install && pnpm run build",
    "build": "pnpm run build:harness",
    "build:harness": "(test -d .oh/cli/node_modules || npm --prefix .oh/cli ci --ignore-scripts) && npm --prefix .oh/cli run build",
    "test": "vitest run",
    "test:scripts": "vitest run",
    "lint": "echo \"No root lint configured\"",
    "format:check": "echo \"No root format check configured\"",
    "typecheck": "(test -d .oh/cli/node_modules || npm --prefix .oh/cli ci --ignore-scripts) && npm --prefix .oh/cli run typecheck",
    "format": "echo \"No root formatter configured\"",
    "pnpm:devPreinstall": "pnpm run security:audit",
    "security:audit": "pnpm audit --audit-level low --ignore-registry-errors"
  },
  "dependencies": {
    "croner": "^9.1.0"
  },
  "devDependencies": {
    "@sinclair/typebox": "^0.34.0",
    "diff": "^8.0.2",
    "fast-check": "^4.8.0",
    "vitest": "^3.2.6"
  },
  "engines": {
    "node": ">=20.0.0"
  },
  "pnpm": {
    "overrides": {
      "esbuild": "^0.28.1"
    }
  }
}
